# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin PIN (para acceso a caja) - debe tener prefijo NEXT_PUBLIC_ por ser usado en cliente
NEXT_PUBLIC_ADMIN_PIN=1234

# ─────────────────────────────────────────
# Configuración para WhatsApp Cloud Function
# ─────────────────────────────────────────
# Estas NO van en .env.local, se configuran con Firebase CLI:
#
#   firebase functions:config:set \
#     whatsapp.token="EAAx..." \
#     whatsapp.phoneid="123456789..." \
#     whatsapp.channelid="50581234567"
#
# Luego despliega: firebase deploy --only functions
